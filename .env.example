# ── LLM Provider ──────────────────────────────────────────────
# Opções: gemini, openai, groq
LLM_PROVIDER=gemini

# Cole aqui a API key do provider selecionado
LLM_API_KEY=your-api-key-here

# ── Gemini ────────────────────────────────────────────────────
# Modelo padrão do Gemini (pode trocar para gemini-2.0-flash, etc.)
GEMINI_MODEL=gemini-2.5-flash

# ── Groq ─────────────────────────────────────────────────────
# Modelo padrao do Groq (llama-3.3-70b-versatile, mixtral-8x7b-32768, etc.)
GROQ_MODEL=llama-3.3-70b-versatile

# ── brapi.dev ─────────────────────────────────────────────────
# Dados financeiros brasileiros — https://brapi.dev
# Free: 15.000 req/mes. Cadastre-se em https://brapi.dev
# Sem token funciona para: PETR4, MGLU3, VALE3, ITUB4
BRAPI_TOKEN=

# ── Research ──────────────────────────────────────────────────
# Quantidade máxima de resultados de busca
SEARCH_MAX_RESULTS=8
