# ── LLM Provider ──────────────────────────────────────────────
# Opções: gemini, openai, groq
LLM_PROVIDER=gemini

# Cole aqui a API key do provider selecionado
LLM_API_KEY=your-api-key-here

# ── Gemini ────────────────────────────────────────────────────
# Modelo padrão do Gemini (pode trocar para gemini-2.0-flash, etc.)
GEMINI_MODEL=gemini-2.5-flash

# ── Groq ─────────────────────────────────────────────────────
# Modelo padrao do Groq (llama-3.3-70b-versatile, mixtral-8x7b-32768, etc.)
GROQ_MODEL=llama-3.3-70b-versatile

# ── Dados Financeiros ──────────────────────────────────────────
# Fonte primária: Yahoo Finance (yfinance) — automático, sem token
# brapi.dev é usado como fallback (opcional)
# Cadastre-se em https://brapi.dev para obter um token gratuito
BRAPI_TOKEN=

# ── Research ──────────────────────────────────────────────────
# Quantidade máxima de resultados de busca
SEARCH_MAX_RESULTS=8
